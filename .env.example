# Copy to .env: cp .env.example .env

# Builds (e.g. Vercel) succeed without Apple/Discord/Turnstile; the contact API
# returns 503 until DISCORD_WEBHOOK and TURNSTILE_SECRET_KEY are set in the dashboard.

APPLE_TEAM_ID=localdev
APPLE_KEY_ID=localdev
APPLE_PRIV_KEY=REPLACE_WITH_APPLE_MAPKIT_P8_KEY
DISCORD_WEBHOOK=https://example.com/
TURNSTILE_SECRET_KEY=localdev

# Optional — Apple-like static map when MapKit keys aren’t set (free tier at mapbox.com)
# MAPBOX_ACCESS_TOKEN=

# Optional — Vercel KV / Redis for “last visitor” on /stats and shared Spotify “now playing” cache
# (avoids hitting Spotify once per visitor). Use either pair — `vercel env pull` usually writes one of:
# KV_REST_API_URL= + KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL= + UPSTASH_REDIS_REST_TOKEN=

# Optional — Spotify “now playing” without Discord (developer.spotify.com app; scopes:
# user-read-currently-playing, user-read-playback-state).
# 1) Put SPOTIFY_CLIENT_ID + SPOTIFY_CLIENT_SECRET here (no refresh token yet).
# 2) In the Spotify app settings add redirect URI: http://127.0.0.1:8888/callback
# 3) Run: bun run spotify:auth — paste printed SPOTIFY_REFRESH_TOKEN below.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=

# Optional — PartyKit host for /experiments/tic-tac-toe (default: localhost:1999 with `bun run dev:multiplayer`)
# Production: run `bun run deploy:party` (or `bunx partykit deploy`), then set this in Vercel to the printed host — no https://
# Full steps: docs/tic-tac-toe-deployment.md
# NEXT_PUBLIC_PARTYKIT_HOST=

# Reserved for reuse (not read by the app today)
# JWT_SIGNING_SECRET=
# APP_URL=http://localhost:3000
# DEFAULT_LOCATION=London
